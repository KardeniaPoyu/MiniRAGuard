# ============================================================
# .dockerignore — Docker 构建时排除的文件
# ============================================================

# 密钥和本地环境
.env
.env.*
*.env

# 虚拟环境
.venv/
venv/

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 运行时产物（容器中重新生成）
cache.db
backend/cache.db
backend/vector_store/

# Git
.git/
.gitignore
.gitattributes
.github/

# 日志
*.log
uvicorn_*.log

# OS
.DS_Store
Thumbs.db
Desktop.ini

# 测试图片
test_*.jpg
test_*.png

# IDE
.vscode/
.idea/
.cursorrules
.editorconfig

# 文档
docs/
README.md
