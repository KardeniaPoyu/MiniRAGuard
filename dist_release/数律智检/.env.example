# 数律智检 · 环境变量配置模板
# 复制此文件为 .env 并填写真实值（.env 已被 .gitignore 排除，不会提交至代码库）

# ── AI 推理密钥（必填）─────────────────────────────────────────────────────
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── JWT 安全密钥（必填）────────────────────────────────────────────────────
# 建议使用随机字符串，例如：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_secret_string

# ── 运行模式（可选）──────────────────────────────────────────────────────
# 设为 true 时跳过测试数据植入，适合生产环境
PRODUCTION=false
