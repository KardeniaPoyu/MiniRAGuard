# ============================================================
# Qingju (青居智选) - Environment Variables Example
# Copy this file to .env and fill in the values
# ============================================================

# ---------- DeepSeek API (Core Reasoning) ----------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ---------- Qwen-VL API (OCR / Contract Extraction) ----------
QWEN_API_KEY=your_qwen_api_key_here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-vl-max

# ---------- Server Configuration ----------
# Set to 'true' for production deployment
PRODUCTION=false

# Secret key for JWT signing (REQUIRED for production). Generate a long random string.
# SECRET_KEY=your_secret_key_here

# Comma-separated list of allowed origins for CORS. 
# Defaults to "*" in development (if PRODUCTION=false).
# In production, specify your domain: http://yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://yourdomain.com

# Mock Data / Initial Users (Defaults to true if PRODUCTION=false)
# SEED_MOCK_DATA=true
# SEED_USERS=true

# Maximum concurrent contract analysis tasks (autodetected if empty)
# MAX_CONCURRENT_ANALYZE=2

# ---------- Database / Persistence ----------
# SQLite database is stored in rent_agent_backend/data/
# Vector store is stored in rent_agent_backend/vector_store/
